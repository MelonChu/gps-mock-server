<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- 頂部拖動條 -->
    <LinearLayout
        android:id="@+id/drag_handle"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:background="@drawable/bg_handle">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌸 拖動"
            android:textSize="11sp"
            android:textColor="#CCCCCC"
            android:paddingHorizontal="4dp"/>

        <ImageButton
            android:id="@+id/btn_minimize"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@null"
            android:scaleType="centerInside"
            android:contentDescription="隱藏"/>

    </LinearLayout>

    <!-- 搖桿 -->
    <com.pikmin.standalone.views.JoystickView
        android:id="@+id/joystick"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="center"
        android:layout_margin="4dp"/>

    <!-- 控制列 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#66000000">

        <TextView
            android:id="@+id/roam_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="遊蕩模式 ✋"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"/>

        <ToggleButton
            android:id="@+id/toggle_roam"
            android:layout_width="56dp"
            android:layout_height="32dp"
            android:textOn="ON"
            android:textOff="OFF"
            android:textSize="11sp"
            android:checked="false"/>

    </LinearLayout>

</LinearLayout>
