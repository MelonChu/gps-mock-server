<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/drag_handle"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:background="@drawable/bg_handle">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌸 Pikmin助手"
            android:textSize="11sp"
            android:textColor="#CCC"
            android:paddingHorizontal="8dp"/>
        <ImageButton
            android:id="@+id/btn_minimize"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@null"
            android:contentDescription="關閉"/>
    </LinearLayout>

    <!-- 狀態列 -->
    <TextView
        android:id="@+id/status_gps"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:text="⏳ GPS 初始化中..."
        android:textSize="10sp"
        android:textColor="#FFCC00"
        android:gravity="center"
        android:background="#88000000"/>

    <!-- 搖桿 -->
    <com.gpsmock.server.views.JoystickView
        android:id="@+id/joystick"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="center"/>

    <!-- 下排控制 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp"
        android:background="#66000000">

        <!-- 步數 + 游蕩 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/roam_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="游蕩 ✋ | 0步"
                android:textSize="11sp"
                android:textColor="#FFF"
                android:layout_marginEnd="4dp"/>
            <ToggleButton
                android:id="@+id/toggle_roam"
                android:layout_width="44dp"
                android:layout_height="26dp"
                android:textOn="ON"
                android:textOff="OFF"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- Google 同步 -->
        <Button
            android:id="@+id/btn_google_sync"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:text="🔗 Google 同步步數"
            android:textSize="9sp"
            android:layout_marginTop="4dp"
            android:padding="2dp"
            android:backgroundTint="#4285F4"/>

    </LinearLayout>

</LinearLayout>
